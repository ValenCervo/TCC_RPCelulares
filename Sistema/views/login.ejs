<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- FONTE -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    
    <link rel='stylesheet' href='/stylesheets/style.css' />
       
    <!-- ICONES -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
        
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <title>Login</title>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-loginCadastro">
  <div class="left-group">
    <div class="logo">RP</div>

    <div class="nav-links">
      <a href="/" class="active">Início</a>
      <a href="/conserto">Sobre Nós</a>
      <a href="/produtos">Conserto</a>
    </div>
  </div>

  <div class="icons">
    <div class="icon">
      <i class="bi bi-person-circle"></i>
    </div>
  </div>
</nav>

<!-- CONTEÚDO -->
<div class="login-container">

  <!-- LADO ESQUERDO -->
  <div class="left-side">
    <h1>BEM-VINDO DE VOLTA!</h1>
    <p>
      Estamos felizes em te ver por aqui de novo!
      Confira as novidades da RP Celulares.
    </p>

    <div class="icon-circle">
      <i class="bi bi-tools"></i>
    </div>
  </div>

  <!-- LADO DIREITO -->
  <div class="right-side">
    <h2>LOGIN</h2>

    <form>

      <!-- Email -->
      <div class="input-box">
        <i class="bi bi-envelope-fill"></i>
        <input type="text" placeholder="E-mail ou nome de usuário">
      </div>

      <!-- Senha -->
      <div class="input-box senha-box">
        <i class="bi bi-lock-fill"></i>
        <input type="password" id="senha" placeholder="Senha">
        <i class="bi bi-eye-slash toggle-senha" id="toggleSenha"></i>
      </div>

      <!-- Opções -->
      <div class="options">
        <label>
          <input type="checkbox"> Lembrar-me
        </label>
        <a href="/recuperar">Esqueceu a senha?</a>
      </div>

      <!-- Botão -->
      <button type="submit" class="btn-login">ENTRAR</button>

      <!-- Cadastro -->
      <p class="register">
        Não tem uma conta? <a href="/cadastro">Cadastre-se</a>
      </p>

      <p class="social-text">Fazer login com</p>

      <!-- Redes (clicáveis) -->
      <div class="social-icons">
        <a href="/auth/facebook">
          <i class="bi bi-facebook"></i>
        </a>

        <a href="/auth/google">
          <img src="/images/google-logo.jpg" alt="google" class="bi-google">
        </a>

        <a href="/auth/apple">
          <i class="bi bi-apple"></i>
        </a>
      </div>

    </form>
  </div>

</div>

<!-- SCRIPT SENHA -->
<script>
  const inputSenha = document.getElementById("senha");
  const toggle = document.getElementById("toggleSenha");

  toggle.addEventListener("click", () => {
    if (inputSenha.type === "password") {
      inputSenha.type = "text";
      toggle.classList.remove("bi-eye-slash");
      toggle.classList.add("bi-eye");
    } else {
      inputSenha.type = "password";
      toggle.classList.remove("bi-eye");
      toggle.classList.add("bi-eye-slash");
    }
  });
</script>

</body>
</html>