<!DOCTYPE html>
<html>
  <head>
    <title>RP Celulares</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
        <!--ICONES-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
        <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body>
    <!-- NAVBAR-->
<nav class="navbar navbar-custom">

<div class="left-group">
  <div class="logo">RP</div>

  <div class="nav-links">
    <a href="/">Início</a>
    <a href="/conserto">Sobre Nós</a>
    <a href="/produtos" class="active">Conserto</a>
  </div>
</div>

  <!-- Busca -->
  <div class="search-box">
    <input type="text" placeholder="O que você procura?">
    <i class="bi bi-search"></i>
  </div>

  <!-- Ícones -->
  <div class="icons">

    <!-- Carrinho -->
    <div class="icon cart">
      <i class="bi bi-cart3"></i>
    </div>

    <!-- Conta -->
    <div class="icon">
      <i class="bi bi-person-circle"></i>
    </div>

    <!-- Menu -->
    <div class="icon" data-bs-toggle="offcanvas" data-bs-target="#menuLateral">
      <i class="bi bi-list"></i>
    </div>

  </div>
</nav>

<!-- CARROSEL -->
<div id="carouselExample" class="carousel slide">
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="/images/propaganda1.png" class="d-block w-100" alt="Banner 1">
    </div>

  </div>

  <!-- Botões -->
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="menuLateral">
  <div class="offcanvas-body">
    <ul class="list-group">
      <li class="list-group-item"><a href="/" class="text-decoration-none">Início</a></li>
      <li class="list-group-item">Lançamentos</li>
      <li class="list-group-item">Mais Vendidos</li>
      <li class="list-group-item">Celular</li>
      <li class="list-group-item">Computador</li>
      <li class="list-group-item">Cabos/Carregadores</li>
      <li class="list-group-item">Fones de ouvido</li>
      <li class="list-group-item">Acessórios</li>
      <li class="list-group-item">Adaptadores</li>
    </ul>
  </div>
</div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
